generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  USER
  ROOM_ADMIN
  PLATFORM_ADMIN
}

enum VoteType {
  UP
  DOWN
}

enum QueueItemStatus {
  QUEUED
  PLAYING
  PLAYED
  REMOVED
}

enum BoostType {
  BOOST
  PRIORITY_BOOST
  PLAY_NEXT
  SUPER_PRIORITY
}

enum PaymentMethod {
  FIAT
  CRYPTO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProposalStatus {
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
}

enum BadgeType {
  TOP_VOTER
  EARLY_SUPPORTER
  POWER_LISTENER
  TOP_CONTRIBUTOR
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  role          UserRole  @default(USER)
  walletAddress String?   @unique
  crowdBalance  Float     @default(0)
  guestId       String?   @unique
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  ownedRooms    Room[]           @relation("RoomOwner")
  queueItems    QueueItem[]      @relation("AddedBy")
  votes         Vote[]
  chatMessages  ChatMessage[]
  boosts        Boost[]
  tips          Tip[]            @relation("Tipper")
  tipsReceived  Tip[]            @relation("TipReceiver")
  badges        UserBadge[]
  bans          RoomBan[]        @relation("BannedUser")
  bansIssued    RoomBan[]        @relation("BannedBy")
  proposals     Proposal[]
  proposalVotes ProposalVote[]
  transactions  TokenTransaction[]
  nftMembership NftMembership?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  ownerId         String
  cooldownMinutes Int      @default(20)
  queueLocked     Boolean  @default(false)
  maxQueueSize    Int      @default(50)
  voteCooldownSec Int      @default(5)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner       User          @relation("RoomOwner", fields: [ownerId], references: [id])
  queueItems  QueueItem[]
  chatMessages ChatMessage[]
  bans        RoomBan[]
  boosts      Boost[]
  playback    PlaybackState?
  analytics   RoomAnalytics?
}

model QueueItem {
  id          String          @id @default(cuid())
  roomId      String
  youtubeId   String
  title       String
  thumbnail   String
  channel     String?
  duration    Int             @default(0)
  addedById   String?
  guestId     String?
  voteScore   Int             @default(0)
  boostLevel  Int             @default(0)
  status      QueueItemStatus @default(QUEUED)
  position    Int             @default(0)
  playedAt    DateTime?
  createdAt   DateTime        @default(now())

  room    Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  addedBy User?  @relation("AddedBy", fields: [addedById], references: [id])
  votes   Vote[]
  boosts  Boost[]

  @@index([roomId, status])
  @@index([roomId, voteScore])
}

model Vote {
  id          String   @id @default(cuid())
  queueItemId String
  userId      String?
  guestId     String?
  type        VoteType
  createdAt   DateTime @default(now())

  queueItem QueueItem @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@unique([queueItemId, userId])
  @@unique([queueItemId, guestId])
}

model PlaybackState {
  id              String   @id @default(cuid())
  roomId          String   @unique
  currentItemId   String?
  isPlaying       Boolean  @default(true)
  currentTime     Float    @default(0)
  startedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model CooldownEntry {
  id        String   @id @default(cuid())
  roomId    String
  youtubeId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([roomId, youtubeId])
  @@index([roomId, expiresAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String?
  guestId   String?
  guestName String?
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  room Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([roomId, createdAt])
}

model RoomBan {
  id        String   @id @default(cuid())
  roomId    String
  userId    String?
  guestId   String?
  bannedById String
  reason    String?
  createdAt DateTime @default(now())

  room     Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User? @relation("BannedUser", fields: [userId], references: [id])
  bannedBy User  @relation("BannedBy", fields: [bannedById], references: [id])

  @@unique([roomId, userId])
  @@unique([roomId, guestId])
}

model Boost {
  id          String        @id @default(cuid())
  roomId      String
  queueItemId String
  userId      String
  type        BoostType
  amount      Float
  method      PaymentMethod
  paymentId   String?
  txHash      String?
  createdAt   DateTime      @default(now())

  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  queueItem QueueItem @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model Tip {
  id         String        @id @default(cuid())
  roomId     String
  tipperId   String
  receiverId String
  amount     Float
  method     PaymentMethod
  paymentId  String?
  txHash     String?
  createdAt  DateTime      @default(now())

  tipper   User @relation("Tipper", fields: [tipperId], references: [id])
  receiver User @relation("TipReceiver", fields: [receiverId], references: [id])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  amount      Float
  currency    String        @default("INR")
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  razorpayId  String?
  txHash      String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  type      BadgeType
  earnedAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model RoomAnalytics {
  id            String   @id @default(cuid())
  roomId        String   @unique
  totalVotes    Int      @default(0)
  totalSongs    Int      @default(0)
  totalRevenue  Float    @default(0)
  peakUsers     Int      @default(0)
  updatedAt     DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model PlatformAnalytics {
  id        String   @id @default("platform")
  dau       Int      @default(0)
  mau       Int      @default(0)
  revenue   Float    @default(0)
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  type      String
  txHash    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model NftMembership {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenId   String   @unique
  txHash    String?
  mintedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Proposal {
  id          String         @id @default(cuid())
  title       String
  description String
  proposerId  String
  status      ProposalStatus @default(ACTIVE)
  votesFor    Int            @default(0)
  votesAgainst Int           @default(0)
  executedAt  DateTime?
  createdAt   DateTime       @default(now())
  endsAt      DateTime

  proposer User           @relation(fields: [proposerId], references: [id])
  votes    ProposalVote[]
}

model ProposalVote {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  support    Boolean
  weight     Int      @default(1)
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([proposalId, userId])
}

model GovernanceConfig {
  id                 String @id @default("config")
  cooldownMinutes    Int    @default(20)
  maxQueueSize       Int    @default(50)
  boostPrice         Float  @default(10)
  priorityBoostPrice Float  @default(25)
  playNextPrice      Float  @default(50)
  superPriorityPrice Float  @default(100)
  creatorSharePercent  Int  @default(70)
  platformSharePercent Int  @default(30)
}
